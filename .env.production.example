# OptiView Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL username (default: postgres)
DB_USERNAME=postgres

# PostgreSQL password - CHANGE THIS to a secure password
# Generate a strong password: openssl rand -base64 32
DB_PASSWORD=your_secure_password_here

# PostgreSQL database name (default: optiview)
DB_DATABASE=optiview

# ===========================================
# Frontend Configuration
# ===========================================

# API URL for frontend to connect to backend
# Leave empty for same-origin deployment. The frontend will assume the API is available under /api.
# Or full URL for cross-origin: https://api.yourdomain.com
VITE_API_URL=

# ===========================================
# Optional: Custom Ports
# ===========================================

# Uncomment to use custom ports
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
