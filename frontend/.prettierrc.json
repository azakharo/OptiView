{
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": false,
  "arrowParens": "avoid",
  "plugins": ["prettier-plugin-classnames", "prettier-plugin-tailwindcss"],
  "endingPosition": "relative",
  "printWidth": 80,
  "tailwindAttributes": ["theme"],
  "tailwindFunctions": ["twMerge", "createTheme"]
}
